  // ============================================================
  // ── 화면: 이름 선택 (최초 1회) ──
  // ============================================================
  async function renderSetup() {
    await loadStudents();
    const available = studentList.filter(s => !s.uid);

    setApp(`
      <div class="header">
        <div class="header-left">
          <div>
            <div class="header-title">🌟 미라클 6월</div>
            <div class="header-sub">1학년 2반</div>
          </div>
        </div>
        <div class="header-right">
          <button class="btn-signout" id="btnSignout0">로그아웃</button>
        </div>
      </div>
      <div class="setup-wrap">
        <div class="setup-card">
          <div class="em">👋</div>
          <h2>처음 오셨군요!</h2>
          <p>
            <strong>${currentUser.displayName}</strong>님,<br>
            반에서 <strong>내 이름</strong>을 선택해주세요.<br>
            한 번만 설정하면 다음부터 자동 로그인됩니다.
          </p>
          <select class="select-name" id="selStudent">
            <option value="">-- 내 이름 선택 --</option>
            ${available.map(s =>
              `<option value="${s.id}">${s.number}번 ${s.name}</option>`
            ).join('')}
          </select>
          <button class="btn-primary" id="btnConfirm">확인</button>
        </div>
      </div>
    `);

    document.getElementById('btnSignout0').addEventListener('click', () => signOut(auth));

    document.getElementById('btnConfirm').addEventListener('click', async () => {
      const sel = document.getElementById('selStudent').value;
      if (!sel) { showToast('이름을 선택해주세요'); return; }

      const student = studentList.find(s => s.id === sel);
      userProfile = { studentId: sel, name: student.name, role: 'student' };

      await setDoc(doc(db, 'users', currentUser.uid), userProfile);
      await setDoc(doc(db, 'students', sel), { uid: currentUser.uid }, { merge: true });

      await loadStudents();
      renderMain();
    });
  }

  // ============================================================
  // ── 화면: 메인 (학생 목록) ──
  // ============================================================
  async function renderMain() {
    const teacher = isTeacher(currentUser);
    await loadStudents();

    setApp(`
      <div class="header">
        <div class="header-left">
          <div>
            <div class="header-title">🌟 미라클 6월</div>
            <div class="header-sub">1학년 2반 · 2026년 6월</div>
          </div>
          ${teacher ? '<span class="badge-teacher">교사</span>' : ''}
        </div>
        <div class="header-right">
          ${currentUser.photoURL
            ? `<img class="user-avatar" src="${currentUser.photoURL}" referrerpolicy="no-referrer">`
            : ''}
          <span class="user-name">${teacher ? currentUser.displayName : (userProfile?.name || '')}</span>
          <button class="btn-signout" id="btnSignout">로그아웃</button>
        </div>
      </div>

      <div class="main-wrap">
        ${teacher ? `
          <div class="section-title">🔧 교사 관리 — 학생 추가</div>
          <div class="admin-panel" style="margin-bottom:0">
            <div class="admin-title">학생 추가 (한 명씩)</div>
            <div class="admin-row">
              <input class="admin-input" id="adminNum" type="number" placeholder="출석번호" min="1" max="40">
              <input class="admin-input" id="adminName" placeholder="학생 이름">
              <button class="btn-admin" id="btnAdd">+ 추가</button>
            </div>
          </div>
        ` : ''}

        <div class="section-title">📅 6월 주요 일정</div>
        <div class="schedule-grid">
          ${JUNE_SCHEDULE.map(s => `
            <div class="schedule-item">
              <div class="schedule-date">${s.date}</div>
              <div class="schedule-event">${s.event}</div>
            </div>
          `).join('')}
        </div>

        <div class="section-title">👥 우리 반 친구들</div>
        <div class="student-grid" id="studentGrid">
          ${renderCards()}
        </div>
      </div>
    `);

    document.getElementById('btnSignout').addEventListener('click', () => signOut(auth));

    if (teacher) {
      document.getElementById('btnAdd').addEventListener('click', async () => {
        const num  = parseInt(document.getElementById('adminNum').value);
        const name = document.getElementById('adminName').value.trim();
        if (!num || !name) { showToast('번호와 이름을 입력해주세요'); return; }
        const id = 'student_' + String(num).padStart(2, '0');
        await setDoc(doc(db, 'students', id), { number: num, name, uid: null });
        showToast(`${name} 학생 추가됨 ✓`);
        document.getElementById('adminNum').value  = '';
        document.getElementById('adminName').value = '';
        await loadStudents();
        document.getElementById('studentGrid').innerHTML = renderCards();
        attachCards();
      });
    }

    attachCards();
  }

  function renderCards() {
    if (!studentList.length) {
      return `<div class="empty-state"><div class="em">👥</div>
        ${isTeacher(currentUser) ? '위 패널에서 학생을 추가해주세요.' : '학생 목록이 없습니다.'}
      </div>`;
    }
    return studentList.map(s => {
      const isMe = userProfile?.studentId === s.id;
      return `
        <div class="student-card${isMe ? ' is-me' : ''}" data-sid="${s.id}">
          ${s.uid ? '<div class="active-dot"></div>' : ''}
          <div class="student-num">${s.number}번</div>
          <div class="student-icon">${s.name.charAt(0)}</div>
          <div class="student-name">${s.name}</div>
        </div>
      `;
    }).join('');
  }

  function attachCards() {
    document.querySelectorAll('.student-card').forEach(card =>
      card.addEventListener('click', () => renderStudentPage(card.dataset.sid))
    );
  }

  // ============================================================
  // ── 화면: 학생 개별 페이지 ──
  // ============================================================
  async function renderStudentPage(studentId) {
    const student = studentList.find(s => s.id === studentId);
    if (!student) { showToast('학생 정보를 찾을 수 없습니다'); return; }

    const editable = canEdit(studentId);
    const goals    = await loadGoals(studentId);
    sessionData    = JSON.parse(JSON.stringify(goals));

    const weeksHtml = WEEKS.map(wk => {
      const wData = goals[`week${wk.num}`] || {};

      const daysHtml = DAYS.map(day => {
        const cell = wData[day.key] || {};
        return `
          <div class="day-cell${day.sat ? ' sat' : ''}">
            <div class="day-header">
              <span>${day.label}</span>
              ${editable ? `
                <label class="btn-photo" style="width:auto;padding:2px 8px;margin:0">
                  📷
                  <input type="file" accept="image/*" style="display:none"
                    class="photo-file" data-w="${wk.num}" data-d="${day.key}">
                </label>
              ` : ''}
            </div>
            <textarea class="day-text"
              data-w="${wk.num}" data-d="${day.key}"
              placeholder="${day.sat ? '이번 주를 돌아보며...' : '오늘의 목표를 적어요'}"
              ${editable ? '' : 'disabled'}>${cell.text || ''}</textarea>
            <div class="photo-wrap" id="photo-${wk.num}-${day.key}">
              ${cell.photoURL
                ? `<img class="photo-preview-img" src="${cell.photoURL}" alt="사진">`
                : (editable ? `<label class="btn-photo" style="cursor:pointer">
                    📷 사진 추가
                    <input type="file" accept="image/*" style="display:none"
                      class="photo-file" data-w="${wk.num}" data-d="${day.key}">
                   </label>` : '')}
            </div>
          </div>
        `;
      }).join('');

      return `
        <div class="week-col ${wk.cls}">
          <div class="week-title">${wk.label}</div>
          <div class="week-dates-label">${wk.dates}</div>
          <textarea class="week-goal"
            data-w="${wk.num}"
            placeholder="${wk.label} 목표를 입력하세요"
            ${editable ? '' : 'disabled'}>${wData.goal || ''}</textarea>
          ${daysHtml}
        </div>
      `;
    }).join('');

    setApp(`
      <div class="header">
        <div class="header-left">
          <button class="btn-back" id="btnBack">← 목록</button>
          <div>
            <div class="header-title">${student.name} · 미라클 6월</div>
            <div class="header-sub">
              ${editable
                ? (isTeacher(currentUser) ? '🔧 교사 수정 모드' : '✏️ 내 페이지')
                : '👁 열람 모드'}
            </div>
          </div>
        </div>
        <div class="header-right">
          ${currentUser.photoURL
            ? `<img class="user-avatar" src="${currentUser.photoURL}" referrerpolicy="no-referrer">`
            : ''}
          <button class="btn-signout" id="btnSignout2">로그아웃</button>
        </div>
      </div>

      <div class="student-wrap">
        ${!editable
          ? '<div class="view-banner">👁 열람 전용 — 수정하려면 자신의 페이지로 이동하세요.</div>'
          : ''}

        <div class="monthly-section">
          <div class="monthly-label">🎯 6월의 목표</div>
          <textarea class="monthly-input" id="monthlyGoal"
            placeholder="이번 6월에 이루고 싶은 목표를 적어보세요"
            ${editable ? '' : 'disabled'}>${goals.monthlyGoal || ''}</textarea>
        </div>

        <div class="weeks-grid">
          ${weeksHtml}
        </div>
      </div>

      ${editable ? `
        <div class="save-bar">
          <button class="btn-save" id="btnSave">💾 저장하기</button>
        </div>
      ` : ''}
    `);

    initAutoResize();

    document.getElementById('btnBack').addEventListener('click', renderMain);
    document.getElementById('btnSignout2').addEventListener('click', () => signOut(auth));

    if (!editable) return;

    // ── 사진 업로드 ──
    document.querySelectorAll('.photo-file').forEach(input => {
      input.addEventListener('change', async () => {
        const file = input.files[0];
        if (!file) return;
        const w = input.dataset.w;
        const d = input.dataset.d;

        showToast('사진 업로드 중... ⏳', 8000);
        try {
          const url = await uploadPhoto(studentId, w, d, file);

          // sessionData 갱신
          if (!sessionData[`week${w}`])        sessionData[`week${w}`]        = {};
          if (!sessionData[`week${w}`][d])      sessionData[`week${w}`][d]      = {};
          sessionData[`week${w}`][d].photoURL = url;

          // UI 갱신
          const wrap = document.getElementById(`photo-${w}-${d}`);
          if (wrap) {
            wrap.innerHTML = `<img class="photo-preview-img" src="${url}" alt="사진">`;
          }
          showToast('사진 업로드 완료 ✓');
        } catch (err) {
          showToast('업로드 실패: ' + err.message);
        }
      });
    });

    // ── 저장 ──
    document.getElementById('btnSave').addEventListener('click', async () => {
      const saveData = {};

      // 6월 목표
      saveData.monthlyGoal = document.getElementById('monthlyGoal').value;

      for (const wk of WEEKS) {
        const wKey = `week${wk.num}`;
        saveData[wKey] = {};

        // 주차 목표
        const wGoal = document.querySelector(`.week-goal[data-w="${wk.num}"]`);
        saveData[wKey].goal = wGoal ? wGoal.value : '';

        // 일별 셀
        for (const day of DAYS) {
          const existing = sessionData[wKey]?.[day.key] || {};
          const ta       = document.querySelector(`.day-text[data-w="${wk.num}"][data-d="${day.key}"]`);
          saveData[wKey][day.key] = {
            text:     ta ? ta.value : (existing.text || ''),
            photoURL: existing.photoURL || ''   // 업로드 핸들러에서 이미 반영됨
          };
        }
      }

      try {
        await saveGoals(studentId, saveData);
        sessionData = JSON.parse(JSON.stringify(saveData));
        showToast('저장 완료 ✓');
      } catch (err) {
        showToast('저장 실패: ' + err.message);
      }
    });
  }

  // ============================================================
  // 앱 시작 — Auth 상태 감시
  // ============================================================
  onAuthStateChanged(auth, async user => {
    if (!user) {
      currentUser = null; userProfile = null;
      renderLogin();
      return;
    }

    currentUser = user;

    if (isTeacher(user)) {
      userProfile = { role: 'teacher' };
      await loadStudents();
      renderMain();
    } else {
      try {
        const snap = await getDoc(doc(db, 'users', user.uid));
        userProfile = snap.exists() ? snap.data() : null;
      } catch { userProfile = null; }

      if (!userProfile?.studentId) {
        renderSetup();
      } else {
        await loadStudents();
        renderMain();
      }
    }
  });
</script>
